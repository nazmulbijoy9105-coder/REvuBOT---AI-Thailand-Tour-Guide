rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Rules
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
        request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['preferredLanguage', 'email'])) || 
        (isAdmin() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']));
    }

    // Conversation Rules
    match /conversations/{convId} {
      function isValidConversation(data) {
        return data.userId is string && data.title is string && data.title.size() <= 200;
      }
      
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidConversation(request.resource.data);
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasAny(['updatedAt', 'lastMessage']);
    }

    // Message Rules
    match /conversations/{convId}/messages/{msgId} {
      function isConvOwner() {
        return get(/databases/$(database)/documents/conversations/$(convId)).data.userId == request.auth.uid;
      }
      
      function isValidMessage(data) {
        return data.sender in ['user', 'ai'] && 
               data.content is string && 
               data.content.size() <= 10000;
      }

      allow get, list: if isSignedIn() && isConvOwner();
      allow create: if isSignedIn() && isConvOwner() && isValidMessage(request.resource.data);
      allow update: if (isSignedIn() && isConvOwner() && 
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['content'])) ||
                      isAdmin();
      allow delete: if isAdmin();
    }

    // FAQ Rules
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Itinerary Rules
    match /itineraries/{itineraryId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }
    
    // Auth logic for admins
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // Audit Log Rules
    match /audit_logs/{logId} {
      allow read, create: if isAdmin();
    }

    // Feedback Rules
    match /feedback/{feedbackId} {
      function isValidFeedback(data) {
        return data.userId is string && data.message is string && data.message.size() <= 2000;
      }
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid && isValidFeedback(request.resource.data);
      allow read: if isAdmin();
    }
  }
}
